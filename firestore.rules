rules_version = '2';



service cloud.firestore {

  match /databases/{database}/documents {

    function isSignedIn() {

      return request.auth != null;

    }



    function isOwner(userId) {

      return isSignedIn() && request.auth.uid == userId;

    }



    function isEmailVerified() {

      return isSignedIn() && request.auth.token.email_verified == true;

    }



    function isAdmin() {

      return isSignedIn()

        && request.auth.uid in ['DhBcumWgN0RLAHK8aSYb3S9jXEv1'];

    }



    function protectedUserFieldsUnchanged() {

      return request.resource.data.uid == resource.data.uid

        && request.resource.data.email == resource.data.email

        && request.resource.data.createdAt == resource.data.createdAt

        && (!('referralCode' in resource.data)

          || request.resource.data.referralCode == resource.data.referralCode)

        && (!('referredBy' in resource.data)

          || request.resource.data.referredBy == resource.data.referredBy);

    }



    function rewardPeriodElapsed() {
      let last = resource.data.get('lastRewardAt', null);
      return last == null
        || request.time > last + duration.value(24, 'h');
    }

    function validRewardedAdGrant() {
      let oldTokens = resource.data.get('tokens', 0);
      let newTokens = request.resource.data.get('tokens', 0);
      let oldAds = resource.data.get('rewardedAdsToday', 0);
      let newAds = request.resource.data.get('rewardedAdsToday', 0);
      return newTokens == oldTokens + 25
        && newAds <= 2
        && (
          newAds == oldAds + 1
          || (rewardPeriodElapsed() && newAds == 1 && oldAds >= 1)
        );
    }

    function validTokenEconomyUpdate() {

      let oldTokens = resource.data.get('tokens', 0);

      let newTokens = request.resource.data.get('tokens', 0);

      return newTokens == oldTokens

        || (newTokens < oldTokens && newTokens >= 0)

        || validRewardedAdGrant();

    }



    function validReferralSelfRewardUpdate() {

      let oldClaimed = resource.data.get('referralRewardClaimed', false);

      let newClaimed = request.resource.data.get('referralRewardClaimed', false);

      let referredBy = resource.data.get('referredBy', '');

      return !oldClaimed

        && newClaimed == true

        && referredBy is string

        && referredBy.size() > 0

        && request.resource.data.get('tokens', 0) == resource.data.get('tokens', 0) + 100;

    }



    function validInviterReferralClaimUpdate() {

      let oldTokens = resource.data.get('tokens', 0);

      let newTokens = request.resource.data.get('tokens', 0);

      let delta = newTokens - oldTokens;

      return delta == 100;

    }



    function validReferralCodeSetUpdate() {

      return !('referralCode' in resource.data)

        && request.resource.data.referralCode is string

        && request.resource.data.referralCode.size() >= 6

        && request.resource.data.get('tokens', 0) == resource.data.get('tokens', 0);

    }



    match /referral_codes/{code} {

      allow read: if isSignedIn();

      allow create: if isSignedIn()

        && request.resource.data.uid == request.auth.uid

        && request.resource.data.code == code;

    }



    match /users/{userId} {

      // Başlangıç jetonu — token_config.dart `initialUserTokens` ile senkron (50).
      function allowedCreateTokenBalance() {
        return ('tokens' in request.resource.data)
          && request.resource.data.tokens is number
          && (request.resource.data.tokens == 50
            || request.resource.data.tokens == 0);
      }

      function validReferredByOnCreate() {
        return !('referredBy' in request.resource.data)
          || (request.resource.data.referredBy is string
              && request.resource.data.referredBy.size() > 0
              && request.resource.data.referredBy != userId);
      }

      function validUserCreate() {
        return request.resource.data.uid == userId
          && request.resource.data.email is string
          && request.resource.data.email.size() >= 3
          && allowedCreateTokenBalance()
          && validReferredByOnCreate();
      }

      function validProfileOnlyUpdate() {
        return request.resource.data.get('tokens', 0) == resource.data.get('tokens', 0)
          && request.resource.data.get('rewardedAdsToday', 0)
            == resource.data.get('rewardedAdsToday', 0)
          && request.resource.data.get('referralRewardClaimed', false)
            == resource.data.get('referralRewardClaimed', false);
      }

      function validMissingTokensBackfill() {
        return (!('tokens' in resource.data) || resource.data.tokens == null)
          && allowedCreateTokenBalance()
          && protectedUserFieldsUnchanged();
      }

      allow read: if isOwner(userId);

      allow create: if isOwner(userId) && validUserCreate();

      allow update: if isOwner(userId)

        && protectedUserFieldsUnchanged()

        && (validProfileOnlyUpdate()

          || validMissingTokensBackfill()

          || validTokenEconomyUpdate()

          || validReferralSelfRewardUpdate()

          || validInviterReferralClaimUpdate()

          || validReferralCodeSetUpdate());

      allow delete: if isOwner(userId);



      match /referral_credits/{creditId} {

        allow read: if isOwner(userId);

        allow create: if isSignedIn()

          && creditId == request.auth.uid

          && request.resource.data.fromUid == request.auth.uid

          && request.resource.data.amount == 100

          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.referredBy == userId;

        allow update, delete: if isOwner(userId);

      }

    }



    match /fortune_requests/{requestId} {

      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;



      allow create: if isEmailVerified()

        && request.resource.data.userId == request.auth.uid

        && request.resource.data.status == 'pending';



      allow update: if isSignedIn()

        && resource.data.userId == request.auth.uid

        && request.resource.data.userId == resource.data.userId;



      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;

    }



    match /couple_compatibility_requests/{requestId} {

      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;



      allow create: if isEmailVerified()

        && request.resource.data.userId == request.auth.uid

        && request.resource.data.status == 'pending';



      allow update: if isSignedIn()

        && resource.data.userId == request.auth.uid

        && request.resource.data.userId == resource.data.userId;



      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;

    }



    match /manual_fortune_requests/{requestId} {

      allow read: if isAdmin()

        || (isSignedIn() && resource.data.userId == request.auth.uid);



      allow create: if isEmailVerified()

        && request.resource.data.userId == request.auth.uid

        && request.resource.data.status == 'pending'

        && request.resource.data.paymentStatus == 'tokens'

        && request.resource.data.tokenCost == 1500

        && request.resource.data.readerId in ['serdar', 'hatice'];



      allow update: if isAdmin();



      allow delete: if isAdmin();

    }

    match /manual_reader_daily_quota/{dayKey} {

      allow read: if isSignedIn();

      allow create: if isEmailVerified()
        && (
          (request.resource.data.get('serdar', 0) == 1
            && request.resource.data.get('hatice', 0) == 0)
          || (request.resource.data.get('hatice', 0) == 1
            && request.resource.data.get('serdar', 0) == 0)
        );

      allow update: if isEmailVerified()
        && (
          (request.resource.data.serdar == resource.data.get('serdar', 0) + 1
            && request.resource.data.serdar <= 20
            && request.resource.data.hatice == resource.data.get('hatice', 0))
          || (request.resource.data.hatice == resource.data.get('hatice', 0) + 1
            && request.resource.data.hatice <= 20
            && request.resource.data.serdar == resource.data.get('serdar', 0))
        );

      allow delete: if false;

    }

    match /play_purchases/{purchaseToken} {

      allow read: if isAdmin()

        || (isSignedIn() && resource.data.uid == request.auth.uid);

      allow create, update, delete: if false;

    }

    match /notification_schedules/{scheduleId} {

      allow read, write: if false;

    }

  }

}


