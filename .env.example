OPENAI_API_KEY=sk-your-key-here
PORT=3000
OPENAI_MODEL=gpt-5.4-mini
VISION_MODEL=gpt-4o-mini
FORTUNE_MAX_COMPLETION_TOKENS=650
COUPLE_MAX_COMPLETION_TOKENS=800
TEMPERATURE=0.9
FREQUENCY_PENALTY=0.55
PRESENCE_PENALTY=0.3
COUPLE_TEMPERATURE=0.9
COUPLE_FREQUENCY_PENALTY=0.6
COUPLE_PRESENCE_PENALTY=0.5

# Firebase Admin SDK — FCM push bildirimleri
# 1) Firebase Console > Project Settings > Service accounts > Generate new private key
# 2) İndirilen JSON'u backend/firebase-service-account.json olarak kaydedin
# 3) Backend'i yeniden başlatın — logda "FCM push bildirimleri aktif." görünmeli
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Alternatif: tüm JSON'u tek satır olarak (production)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
HOST=0.0.0.0
