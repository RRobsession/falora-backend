OPENAI_API_KEY=sk-your-key-here
PORT=3000
OPENAI_MODEL=gpt-5.4-mini
VISION_MODEL=gpt-4o-mini
FORTUNE_MAX_COMPLETION_TOKENS=650
COUPLE_MAX_COMPLETION_TOKENS=800
TEMPERATURE=0.9
FREQUENCY_PENALTY=0.55
PRESENCE_PENALTY=0.3
COUPLE_TEMPERATURE=0.9
COUPLE_FREQUENCY_PENALTY=0.6
COUPLE_PRESENCE_PENALTY=0.5

# Firebase Admin SDK — FCM, auth, Firestore billing
# Railway (production): JSON'un tamamını tek satır olarak ekleyin
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n",...}
#
# Yerel geliştirme fallback:
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
HOST=0.0.0.0

# Google Play Billing doğrulaması
GOOGLE_PLAY_PACKAGE_NAME=com.rrlime.falora
# Tercihen Play Console API erişimi verilmiş servis hesabı:
# GOOGLE_PLAY_SERVICE_ACCOUNT_PATH=./google-play-service-account.json
# veya tek satır JSON:
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Resend — auth e-postaları (doğrulama + şifre sıfırlama)
# Railway Variables:
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=Tombik Teyze <noreply@your-verified-domain.com>
# FIREBASE_EMAIL_CONTINUE_URL=https://falora35.firebaseapp.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=Tombik Teyze <onboarding@resend.dev>
FIREBASE_EMAIL_CONTINUE_URL=https://falora35.firebaseapp.com

